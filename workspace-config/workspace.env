# workspace.env is shell code, which is trusted by the framework.
# It is intended to define the basic variables and functions used by DDF, and should be
# customized for each DDF workspace.

WORKSPACE_NAME=ddf
ORGANIZATION=bob
SERVER_USER=bob
DOCKER_ROOT_IMAGE=ubuntu:noble

# https://robotmoon.com/256-colors/
HOST_COLOR=207
PATH_COLOR=154
