#!/usr/bin/env bash
set -euo pipefail

expand_path() {
  case "$1" in
    "~") echo "$HOME" ;;
    "~/"*) echo "$HOME/${1#~/}" ;;
    "~"*)
      user="${1#~}"
      user="${user%%/*}"
      rest="${1#~$user}"
      home="$(getent passwd "$user" | cut -d: -f6)"
      [[ -n "$home" ]] && echo "$home$rest" || return 1
      ;;
    *) echo "$1" ;;
  esac
}

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
WORKSPACE_ENV="${REPO_ROOT}/workspace-config/workspace.env"

[ -f "${WORKSPACE_ENV}" ] || { printf '%s\n' "No workspace-config/workspace.env found" >&2; exit 1; }
source "${WORKSPACE_ENV}"

SERVER_USER="${SERVER_USER:-$(id -un)}"
SERVER_GROUP="${SERVER_GROUP:-${SERVER_USER}}"

: "${ORGANIZATION:?ORGANIZATION not set}"
: "${WORKSPACE_NAME:?WORKSPACE_NAME not set}"

IS_GIT_DIR=$(if git rev-parse --git-dir > /dev/null 2>&1 ; then echo yes ; else echo no ; fi)
VERSION=$(if [ "${IS_GIT_DIR}" = "yes" ] ; then git rev-parse --short HEAD ; else echo local ; fi)

TARGET_IMAGE_NAME="${ORGANIZATION}/${WORKSPACE_NAME}_img-dev:v${VERSION}"
CONTAINER_NAME="${WORKSPACE_NAME}-dev"

EXISTING_CONTAINER_ID="$(docker ps -aq --filter "name=^/${CONTAINER_NAME}$" | head -n 1)"
if [[ -n "${EXISTING_CONTAINER_ID}" ]]; then
  RUNNING="$(docker inspect --format='{{.State.Running}}' "${EXISTING_CONTAINER_ID}")"

  if [[ "${RUNNING}" = "true" ]]; then
    RUNNING_IMAGE="$(docker inspect --format='{{.Config.Image}}' "${EXISTING_CONTAINER_ID}")"

    if [[ "${RUNNING_IMAGE}" != "${TARGET_IMAGE_NAME}" ]]; then
      echo "ERROR: container ${CONTAINER_NAME} is already running from:"
      echo "  ${RUNNING_IMAGE}"
      echo "Expected:"
      echo "  ${TARGET_IMAGE_NAME}"
      exit 1
    fi

    echo "Container ${CONTAINER_NAME} is already running with expected image ${TARGET_IMAGE_NAME}"
    exit 0
  fi

  echo "Removing stopped container ${CONTAINER_NAME}"
  docker rm "${EXISTING_CONTAINER_ID}" >/dev/null
fi

if [ -z "$(docker images -q "${TARGET_IMAGE_NAME}")" ]; then
    printf '%s\n' "Image ${TARGET_IMAGE_NAME} does not exist locally." >&2
    exit 1
fi

WORKSPACE_MOUNTS=()
if [[ -f "${REPO_ROOT}/workspace-config/project_dirs.bash" ]]; then
    source "${REPO_ROOT}/workspace-config/project_dirs.bash"
    if declare -p PROJECT_DIRS >/dev/null 2>&1; then
        for dir in "${PROJECT_DIRS[@]}"; do
          EXPANDED="$(expand_path "$dir")" || {
              echo "Invalid path: $dir"
              continue
          }
          ABS="$(realpath "${EXPANDED}")"
          NAME="$(basename "${ABS}")"
          WORKSPACE_MOUNTS+=(--mount type=bind,source="${ABS}",target="/projects/${NAME}")
        done
    fi
fi

PROJECT_DOCKER_RUN_ARGS=()

for project_dir in "${PROJECT_DIRS[@]}"; do
  expanded="$(expand_path "$project_dir")"
  abs="$(realpath "$expanded")"

  if [ -d "${abs}/.ddf/runtime/dev-start.d" ]; then
    for hook in "${abs}/.ddf/runtime/dev-start.d/"*.sh; do
      echo "Hook: ${hook}"
      [ -f "$hook" ] || continue
      # shellcheck source=/dev/null
      . "$hook"
    done
  fi
done

: "${DISPLAY:?DISPLAY is not set}"
command -v xauth >/dev/null 2>&1 || { printf '%s\n' "xauth not found" >&2; exit 1; }

XSOCK=/tmp/.X11-unix
[[ -d "${XSOCK}" ]] || { echo "X11 socket dir not found: ${XSOCK}" >&2; exit 1; }
XAUTH_HOST="/tmp/.docker.xauth.${CONTAINER_NAME}"
XAUTH_CONTAINER="/tmp/.docker.xauth"
rm -f "${XAUTH_HOST}"
touch "${XAUTH_HOST}"
xauth nlist "${DISPLAY}" | sed -e 's/^..../ffff/' | xauth -f "${XAUTH_HOST}" nmerge -
chmod 644 "${XAUTH_HOST}"

HOST_UID="$(id -u)"
HOST_GID="$(id -g)"

printf "%s\n" "Starting image ${TARGET_IMAGE_NAME} as ${CONTAINER_NAME}"

docker run \
    --tty \
    --detach \
    --name "${CONTAINER_NAME}" \
    --hostname "${CONTAINER_NAME}" \
    --add-host "${CONTAINER_NAME}:127.0.0.1" \
    --env "DISPLAY" \
    --mount type=bind,source="${XAUTH_HOST}",target="${XAUTH_CONTAINER}",readonly \
    --env "XAUTHORITY=${XAUTH_CONTAINER}" \
    --env "QT_X11_NO_MITSHM=1" \
    --env "HOST_UID=${HOST_UID}" \
    --env "HOST_GID=${HOST_GID}" \
    --env "SERVER_USER=${SERVER_USER}" \
    --env "SERVER_GROUP=${SERVER_GROUP}" \
    --env "HOST_COLOR=${HOST_COLOR:-208}" \
    --env "PATH_COLOR=${PATH_COLOR:-93}" \
    --mount type=bind,source="${XSOCK}",target="${XSOCK}" \
    "${WORKSPACE_MOUNTS[@]}" \
    "${PROJECT_DOCKER_RUN_ARGS[@]}" \
    "${TARGET_IMAGE_NAME}"
